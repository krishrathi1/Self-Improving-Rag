# ============================================
# APEX — Environment Configuration
# Copy this to .env and fill in your values
# ============================================

# --- TigerGraph ---
TIGERGRAPH_HOST=http://localhost:14240
TIGERGRAPH_GRAPH_NAME=APEX_KG
TIGERGRAPH_USERNAME=tigergraph
TIGERGRAPH_PASSWORD=tigergraph
TIGERGRAPH_API_TOKEN=

# --- LLM Provider ---
# Supported: ollama, openai, google, groq
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:latest
OLLAMA_HOST=http://localhost:11434
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=
GROQ_API_KEY=

# --- Embedding ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=3600

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8010
DEBUG=true
LOG_LEVEL=INFO

# --- Evaluation ---
BENCHMARK_BATCH_SIZE=10
CRAG_GRADE_THRESHOLD=0.75
CACHE_CONFIDENCE_THRESHOLD=0.75
